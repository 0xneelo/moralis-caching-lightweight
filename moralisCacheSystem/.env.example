NODE_ENV=development
PORT=3001
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Backend-only. Never expose this in frontend env vars.
MORALIS_API_KEY=
MORALIS_DAILY_CU_BUDGET=5000000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/moralis_cache
REDIS_URL=redis://localhost:6379

CHART_PROVIDER_ENABLED=true
MAX_SYNC_MORALIS_PAGES=3
MAX_SYNC_GAP_CANDLES=3000
DEFAULT_CURRENCY=usd

# Optional simple admin protection for /api/admin/*
ADMIN_API_KEY=change-me
