{
  "name": "moralis-cache-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "concurrently \"npm run dev:local:api\" \"npm run dev:frontend\"",
    "dev:local:api": "tsx watch src/localIndex.ts",
    "dev:frontend": "vite --config client/vite.config.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\" \"npm run dev:frontend\"",
    "dev:docker": "npm run infra:up && npm run migrate && npm run dev:all",
    "dev:worker": "tsx watch src/worker.ts",
    "infra:up": "powershell -ExecutionPolicy Bypass -File scripts/start-infra.ps1",
    "build": "tsc -p tsconfig.json",
    "build:frontend": "vite build --config client/vite.config.ts",
    "build:all": "npm run build && npm run build:frontend",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "schedule": "tsx src/scripts/schedule.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:frontend": "tsc -p client/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run src/e2e",
    "test:e2e:full": "npm run typecheck && npm run typecheck:frontend && npm run test:e2e && npm run build:all",
    "test:e2e:real": "npm run migrate && npm run test:e2e"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "bullmq": "^5.65.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "pg-mem": "^3.0.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.15"
  }
}
